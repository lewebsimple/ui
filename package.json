{
  "name": "@lewebsimple/ui",
  "version": "0.1.1",
  "description": "Vue 3 component library",
  "repository": {
    "type": "git",
    "url": "https://github.com/lewebsimple/ui.git"
  },
  "homepage": "https://github.com/lewebsimple/ui#readme",
  "bugs": "https://github.com/lewebsimple/ui/issues",
  "author": "Pascal Martineau <pascal@lewebimple.ca>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "tailwind-preset.js"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./tailwind-preset": {
      "require": "./tailwind-preset.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && vue-tsc && vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "prepare": "husky install",
    "release": "release-it"
  },
  "devDependencies": {
    "@lewebsimple/eslint-config-vue": "^0.5.5",
    "@release-it/conventional-changelog": "^5.1.1",
    "@types/node": "^18.11.9",
    "@vitejs/plugin-vue": "^3.2.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.27.0",
    "husky": "^8.0.2",
    "nano-staged": "^0.8.0",
    "postcss": "^8.4.19",
    "postcss-prefix-selector": "^1.16.0",
    "release-it": "^15.5.0",
    "rimraf": "^3.0.2",
    "tailwindcss": "^3.2.3",
    "typescript": "^4.8.4",
    "vite": "^3.2.3",
    "vitepress": "1.0.0-alpha.28",
    "vue": "^3.2.45",
    "vue-tsc": "^1.0.9"
  },
  "eslintConfig": {
    "extends": "@lewebsimple/eslint-config-vue"
  },
  "nano-staged": {
    "*.{js,ts,vue}": "eslint --fix --ignore-path .gitignore"
  }
}
